{
  "name": "reiatsu",
  "version": "1.3.0",
  "description": "A minimal TypeScript HTTP server framework, built from first principles.",
  "keywords": [
    "http",
    "webserver",
    "framework",
    "nodejs",
    "typescript",
    "router",
    "middleware",
    "microframework"
  ],
  "homepage": "https://github.com/andi-nugroho/reiatsu#readme",
  "bugs": {
    "url": "https://github.com/andi-nugroho/reiatsu/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andi-nugroho/reiatsu.git"
  },
  "license": "MIT",
  "author": "Andi Nugroho",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --build tsconfig.build.json && tsc-esm-fix dist && node fix-template-engine.cjs",
    "prepare": "npm run build",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "@vitest/coverage-v8": "^3.2.3",
    "tsc-esm-fix": "^3.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=14"
  },
  "peerDependencies": {
    "typescript": ">=4.5"
  },
  "dependencies": {
    "reiatsu": "^1.3.0"
  }
}
